{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=gloss.db"
  },
  "Jwt": {
    "Issuer": "GlossApi",
    "Audience": "GlossClient",
    "Key": "CHANGE_ME_dev_only_signing_key_min_32_chars_long!!",
    "ExpiryMinutes": 120
  },
  "Cors": {
    "AllowedOrigin": "http://localhost:3000"
  }
}
